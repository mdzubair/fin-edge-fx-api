
---

# .gitignore

```gitignore
# Dependencies
node_modules/

# Build
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime Data
pids
*.pid
*.seed
*.pid.lock

# Environment Variables
.env
.env.local
.env.development
.env.production
.env.test

# TypeScript
*.tsbuildinfo

# IDE
.vscode/
.idea/

# OS Files
.DS_Store
Thumbs.db

# Coverage
coverage/

# Cache
.cache/
.nyc_output/

# Temporary Files
tmp/
temp/

# Uploads
# uploads/
# public/uploads/

# Database
*.sqlite
*.db

# Package Locks (Optional)
# package-lock.json
# yarn.lock

# ESLint Cache
.eslintcache

# Prettier Cache
.prettiercache

# Test Output
jest-results.json

# Misc
*.swp
*.swo